---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Theme from '../../components/Theme.astro'
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />

		<!-- Google Analytics -->
		<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-BVP10MBWF2"></script>
		<script is:inline>
		window.dataLayer = window.dataLayer || [];
		function gtag(){dataLayer.push(arguments);}
		gtag('js', new Date());
		gtag('config', 'G-BVP10MBWF2');
		</script>

		<style>
			main {
				width: 960px;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				width: 100%;
				margin-bottom: 1rem;
				text-align: center;
			}
			ul li:first-child img {
				width: 100%;
			}
			ul li:first-child .title {
				font-size: 2.369rem;
			}
			ul li img {
				border-radius: 12px;
			}
			ul li a {
				display: block;
			}
			.title {
				margin: 0;
				line-height: 1;
			}
			.date {
				margin: 0;
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: #404040;
			}
			ul a:hover img {
				box-shadow: theme('boxShadow.xl');
			}
			@media (max-width: 720px) {
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
					text-align: center;
				}
				ul li:first-child {
					margin-bottom: 0;
				}
				ul li:first-child .title {
					font-size: 1.563em;
				}
			}

			/* Zoomin Image */
			.hero-image {
				overflow: hidden;
				border-radius: 1rem;
			}
			a:hover img {
				transform: scale(1.2);
			}

			html.dark ul li a:hover h4,
			ul li a:hover .date {
				color: theme('textColor.neutral.400');
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="mt-20">
			<section>
				<ul>
					{
						posts.map((post) => (
							<li class="border-2 border-grey rounded-xl">
								<a href={`/blog/${post.slug}/`}>
									<div class="hero-image mb-4">
										<img class="transition duration-1000"  width={720} height={360} src={post.data.heroImage} alt={post.data.title} />
									</div>
									<div class="p-2">
										<h4 class="title text-neutral-800 dark:text-neutral-200">{post.data.title}</h4>
										<p class="text-neutral-800 dark:text-neutral-300 line-clamp-1">{post.data.description}</p>
										<p class="date text-neutral-800 dark:text-neutral-300">
											<FormattedDate date={post.data.pubDate} />
										</p>
									</div>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
		<Theme />
	</body>
</html>
